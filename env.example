BOT_TOKEN=123456:ABC-DEF1234ghIkl-mnOPqrst567890uvw
# Used ONLY for embeddings (OpenRouter has no embeddings endpoint).
OPENAI_API_KEY=sk-proj-....
# Used for chat completions, routed through OpenRouter.
OPENROUTER_API_KEY=sk-or-v1-....
# Optional override; defaults to https://openrouter.ai/api/v1
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
ADMIN_IDS=[123456789, 987654321]

# Google
GOOGLE_DOC_ID=1xYz...
# Paste the content of your service_account.json here, ensuring it is a single line if needed or properly quoted.
# Ideally, for Docker, you might mount the file, but the code currently expects a JSON string or path (logic depends on usage). 
# Looking at bot/services/gdocs.py usage with google.oauth2.service_account.Credentials.from_service_account_info, 
# it likely expects the JSON content string if passed directly, or a dict.
# Actually, pydantic Settings reads from .env. Providing the JSON content safely in .env can be tricky due to newlines.
# The current setup reads GOOGLE_SERVICE_ACCOUNT_JSON as a string.
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "...", ...}

# Services (Defaults for Docker Compose)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
# Optional. If set, the Qdrant container will require this key and the bot
# will authenticate with it. Leave empty to disable auth.
QDRANT_API_KEY=
REDIS_URL=redis://redis:6379/0
# Optional. If set, the Redis container will require this password and the bot
# will authenticate with it. Leave empty to disable auth.
REDIS_PASSWORD=
# Max length of a user question we will process (characters).
MAX_QUESTION_LENGTH=1000
